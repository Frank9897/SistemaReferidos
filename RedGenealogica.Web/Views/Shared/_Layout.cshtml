<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RedGenealogica</title>

    <link rel="stylesheet" href="~/css/sistema-referidos.css" />
</head>

<body>

    <!-- NAVBAR PRO -->
    <header class="navbar-custom">
        <div class="nav-container">

            <div class="logo">
                RedGenealogica
            </div>

            <div class="nav-links">

                <a href="/">Inicio</a>
                <a href="/Usuario/Panel">Panel</a>
                <a href="/Ranking">Ranking</a>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <form asp-controller="Autenticacion" asp-action="Logout" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-secondary">Salir</button>
                    </form>
                }
                else
                {
                    <a href="/Autenticacion/Login">Login</a>
                }

            </div>

        </div>
        
        <div style="max-width:1200px; margin:auto; padding:10px 20px;">
            <button onclick="window.history.back()" class="btn-volver">
                ← Volver
            </button>
        </div>
    </header>
    
    <!-- CONTENIDO -->
    <main class="container-dashboard">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="footer-custom">
        <p>© 2026 - RedGenealogica</p>
    </footer>

</body>
</html>

<script>
function volver() {
    window.history.back();
    setTimeout(() => location.reload(), 100);
}
</script>

