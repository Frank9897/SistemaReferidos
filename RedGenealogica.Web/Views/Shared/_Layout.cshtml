<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RedGenealogica</title>
    <link rel="stylesheet" href="~/css/sistema-referidos.css" asp-append-version="true" />
</head>
<body>
    <header class="navbar-custom">
        <div class="nav-container">
            <div class="logo">RedGenealogica</div>
            <div class="nav-links">

                <a href="/">Inicio</a>
                <a href="/Usuario/Panel">Panel</a>
                <a href="/Ranking">Ranking</a>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <form asp-controller="Autenticacion" asp-action="Logout" method="post" class="logout-form">
                        <button type="submit" class="btn btn-secondary">Salir</button>
                    </form>
                }
                else
                {
                    <a href="/Autenticacion/Login">Login</a>
                }

            </div>
        </div>
    </header>

    <div class="main-container">
        @RenderBody()
    </div>

    <footer class="footer-custom">
        <p>© 2026 - RedGenealogica</p>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>