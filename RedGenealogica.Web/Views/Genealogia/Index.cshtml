@model List<RedGenealogica.Web.Models.Usuario>

<h2>Árbol Genealógico</h2>

<div id="arbol" style="height:500px;"></div>

<script src="https://d3js.org/d3.v7.min.js"></script>

<script>
fetch('/Genealogia/ObtenerArbol')
.then(res => res.json())
.then(data => {

    const width = 800;
    const height = 500;

    const svg = d3.select("#arbol")
        .append("svg")
        .attr("width", width)
        .attr("height", height);

    const root = d3.stratify()
        .id(d => d.id)
        .parentId(d => d.padreId)(data);

    const treeLayout = d3.tree().size([width - 100, height - 100]);
    treeLayout(root);

    // líneas
    svg.selectAll('line')
        .data(root.links())
        .enter()
        .append('line')
        .attr('x1', d => d.source.x + 50)
        .attr('y1', d => d.source.y + 50)
        .attr('x2', d => d.target.x + 50)
        .attr('y2', d => d.target.y + 50)
        .attr('stroke', '#38BDF8');

    // nodos
    const nodes = svg.selectAll('circle')
        .data(root.descendants())
        .enter()
        .append('circle')
        .attr('cx', d => d.x + 50)
        .attr('cy', d => d.y + 50)
        .attr('r', 20)
        .attr('fill', d => d.id.startsWith("U_") ? '#3B82F6' : '#F97316');

    // texto
    svg.selectAll('text')
        .data(root.descendants())
        .enter()
        .append('text')
        .attr('x', d => d.x + 50)
        .attr('y', d => d.y + 55)
        .attr('text-anchor', 'middle')
        .attr('fill', 'white')
        .text(d => d.data.nombre);
});
</script>