@{
    ViewBag.MostrarVolver = true;
}

<h2 style="text-align:center;">Árbol Genealógico</h2>
<div id="tooltip" class="tooltip-pro"></div>
<div class="tree-container">
    <div id="arbol"></div>
</div>

<script src="https://d3js.org/d3.v7.min.js"></script>

<script>
fetch('/Genealogia/ObtenerArbol')
.then(res => res.json())
.then(data => {

    const width = 1000;
    const height = 600;

    const svg = d3.select("#arbol")
        .append("svg")
        .attr("viewBox", `0 0 ${width} ${height}`)
        .style("width", "100%")
        .style("height", "100%");

    const g = svg.append("g");

    const zoom = d3.zoom()
        .scaleExtent([0.5, 1.5])
        .on("zoom", (event) => {
            g.attr("transform", event.transform);
        });

    svg.call(zoom);

    const root = d3.stratify()
        .id(d => d.id)
        .parentId(d => d.padreId)(data);

    root.x0 = width / 2;
    root.y0 = 0;

    const treeLayout = d3.tree().nodeSize([120, 90]);

    // 🔥 colapsar inicial
    if (root.children) root.children.forEach(colapsar);

    update(root);

    function colapsar(d) {
        if (d.children) {
            d._children = d.children;
            d._children.forEach(colapsar);
            d.children = null;
        }
    }

    function update(source) {

        treeLayout(root);
        root.each(d => d.y = d.depth * 110);

        const nodes = root.descendants();
        const links = root.links();

        // 🔥 centrar
        const transform = d3.zoomIdentity.translate(width / 2 - root.x, 80);
        svg.transition().duration(400).call(zoom.transform, transform);

        // 🔗 LINKS (ATRÁS)
        const link = g.selectAll("path.link")
            .data(links, d => d.target.id);

        link.enter()
            .append("path")
            .attr("class", "link")
            .attr("fill", "none")
            .attr("stroke", "#38BDF8")
            .attr("stroke-width", 1.5)
            .merge(link)
            .transition()
            .attr("d", d => `
                M${d.source.x},${d.source.y + 25}
                C${d.source.x},${(d.source.y + d.target.y) / 2}
                 ${d.target.x},${(d.source.y + d.target.y) / 2}
                 ${d.target.x},${d.target.y - 25}
            `);

        link.exit().remove();

        // 🧠 NODOS (DELANTE)
        const node = g.selectAll("g.node")
            .data(nodes, d => d.id);

        const nodeEnter = node.enter()
            .append("g")
            .attr("class", "node")
            .attr("transform", d => `translate(${source.x0},${source.y0})`);

        // 🔳 TARJETA
        nodeEnter.append("rect")
            .attr("x", -50)
            .attr("y", -20)
            .attr("width", 100)
            .attr("height", 40)
            .attr("rx", 10)
            .attr("fill", "#0F172A")
            .attr("stroke", d => colorPorRango(d.data.rango))
            .attr("stroke-width", 2);

        // 👤 NOMBRE
        nodeEnter.append("text")
            .attr("text-anchor", "middle")
            .attr("dy", "-2")
            .attr("fill", "#EAF0FF")
            .style("font-size", "12px")
            .text(d => d.data.nombre);

        // 🏷️ ESTADO
        nodeEnter.append("text")
            .attr("text-anchor", "middle")
            .attr("dy", "12")
            .attr("fill", "#94A3B8")
            .style("font-size", "10px")
            .text(d => d.data.estado ?? "");

        // 🟦 TOOLTIP NATIVO (hover)
        const tooltip = d3.select("#tooltip");

        // 🧠 hover
        nodeEnter
            .on("mousemove", (event, d) => {

                tooltip
                    .html(`
                        <div class="tooltip-title">${d.data.nombre}</div>
                        <div class="tooltip-line">Estado: ${d.data.estado ?? "-"}</div>
                        <div class="tooltip-line">Rango: ${d.data.rango}</div>
                        <div class="tooltip-line">Puntos: ${d.data.comision ?? 0}</div>
                    `)
                    .style("left", (event.pageX + 12) + "px")
                    .style("top", (event.pageY + 12) + "px")
                    .classed("show", true);
            })
            .on("mouseleave", () => {
                tooltip.classed("show", false);
    });

        // 🔥 BOTÓN COLLAPSE (debajo)
        const toggle = nodeEnter.append("g")
            .attr("transform", "translate(0, 35)")
            .style("display", d => (d.children || d._children) ? "block" : "none")
            .style("cursor", "pointer")
            .on("click", (event, d) => {

                event.stopPropagation();

                if (d.children) {
                    d._children = d.children;
                    d.children = null;
                } else {
                    d.children = d._children;
                    d._children = null;
                }

                update(d);
            });

        toggle.append("circle")
            .attr("r", 6)
            .attr("fill", "#020617")
            .attr("stroke", "#38BDF8")
            .attr("stroke-width", 1.5)
            .attr("filter", "drop-shadow(0 0 4px #38BDF8)");

        toggle.append("text")
            .attr("text-anchor", "middle")
            .attr("dy", "3")
            .attr("fill", "#38BDF8")
            .style("font-size", "10px")
            .style("pointer-events", "none")
            .text(d => d._children ? "+" : (d.children ? "−" : ""));

        // 🔄 UPDATE
        const nodeUpdate = nodeEnter.merge(node);

        nodeUpdate.transition()
            .attr("transform", d => `translate(${d.x},${d.y})`);

        nodeUpdate.select("title")
            .text(d => 
                `${d.data.nombre}
Estado: ${d.data.estado ?? "-"}
Rango: ${d.data.rango}
Puntos: ${d.data.comision ?? 0}`
            );

        nodeUpdate.select("text:last-child")
            .text(d => d._children ? "+" : (d.children ? "−" : ""));

        nodeUpdate.select("g")
            .style("display", d => (d.children || d._children) ? "block" : "none");

        node.exit().remove();

        nodes.forEach(d => {
            d.x0 = d.x;
            d.y0 = d.y;
        });
    }

});

// 🎨 COLORES
function colorPorRango(rango) {
    switch (rango) {
        case "Diamante": return "#60A5FA";
        case "Platino": return "#22D3EE";
        case "Oro": return "#FFD700";
        case "Plata": return "#C0C0C0";
        case "Bronce": return "#F97316";
        case "Cobre": return "#8B5A2B";
        default: return "#64748B";
    }
}
</script>