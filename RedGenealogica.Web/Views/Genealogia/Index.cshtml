@model List<RedGenealogica.Web.Models.Usuario>
<h2 style="text-align:center;">Árbol Genealógico</h2>

<div class="tree-container">
    <div id="arbol"></div>
</div>

<script src="https://d3js.org/d3.v7.min.js"></script>

<script>
fetch('/Genealogia/ObtenerArbol')
.then(res => res.json())
.then(data => {

    const width = 800;
    const height = 400;

    const svg = d3.select("#arbol")
        .append("svg")
        .attr("viewBox", `0 0 ${width} ${height}`)
        .style("width", "100%")
        .style("height", "100%");

    const g = svg.append("g");

    // 🔥 ZOOM + PAN
    const zoom = d3.zoom()
        .scaleExtent([0.5, 2]) // mínimo y máximo zoom
        .on("zoom", (event) => {
            g.attr("transform", event.transform);
        });

    svg.call(zoom).on("wheel.zoom", null); // evita scroll loco

    const root = d3.stratify()
        .id(d => d.id)
        .parentId(d => d.padreId)(data);
    
    // 🔥 layout BIEN distribuido
    const treeLayout = d3.tree()
        .size([width - 100, height - 100]);

    treeLayout(root);

    // 🔥 centrar árbol automáticamente
    const offsetX = (width / 2) - root.x;
    g.attr("transform", `translate(${offsetX}, 40)`);

    // 🔗 LINKS
    g.selectAll("path")
        .data(root.links())
        .enter()
        .append("path")
        .attr("fill", "none")
        .attr("stroke", "#38BDF8")
        .attr("stroke-width", 1.5)
        .attr("d", d => `
            M${d.source.x},${d.source.y + 20}
            C${d.source.x},${(d.source.y + d.target.y) / 2}
             ${d.target.x},${(d.source.y + d.target.y) / 2}
             ${d.target.x},${d.target.y - 20}
        `);

    // 🧠 NODOS
    const node = g.selectAll(".node")
        .data(root.descendants())
        .enter()
        .append("g")
        .attr("transform", d => `translate(${d.x}, ${d.y})`);

    // 🔳 tarjeta
    node.append("rect")
        .attr("x", -50)
        .attr("y", -20)
        .attr("width", 100)
        .attr("height", 40)
        .attr("rx", 10)
        .attr("fill", "#0F172A")
        .attr("stroke", d => colorPorRango(d.data.rango))
        .attr("stroke-width", 2);

    // 👤 nombre
    node.append("text")
        .attr("text-anchor", "middle")
        .attr("dy", "-2")
        .attr("fill", "#EAF0FF")
        .style("font-size", "12px")
        .style("font-weight", "600")
        .text(d => d.data.nombre);

    // 🏷️ rango
    node.append("text")
        .attr("text-anchor", "middle")
        .attr("dy", "12")
        .attr("fill", d => colorPorRango(d.data.rango))
        .style("font-size", "10px")
        .text(d => d.data.rango);

});

// 🎨 colores
function colorPorRango(rango) {
    switch (rango) {
        case "Diamante": return "#60A5FA";
        case "Platino": return "#22D3EE";
        case "Oro": return "#FFD700";
        case "Plata": return "#C0C0C0";
        case "Bronce": return "#F97316";
        case "Cobre": return "#8B5A2B";
        default: return "#64748B";
    }
}
</script>