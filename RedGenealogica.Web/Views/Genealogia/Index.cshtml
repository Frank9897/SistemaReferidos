@{
    ViewBag.MostrarVolver = true;
}

<h2 style="text-align:center;">Árbol Genealógico</h2>

<div class="tree-container">
    <div id="arbol"></div>
</div>

@await Html.PartialAsync("_BotonVolver")

<script src="https://d3js.org/d3.v7.min.js"></script>

<script>
fetch('/Genealogia/ObtenerArbol')
.then(res => res.json())
.then(data => {

    const width = 1000;
    const height = 600;

    const svg = d3.select("#arbol")
        .append("svg")
        .attr("viewBox", `0 0 ${width} ${height}`)
        .style("width", "100%")
        .style("height", "100%");

    const g = svg.append("g");

    const zoom = d3.zoom()
        .scaleExtent([0.5, 2])
        .on("zoom", (event) => {
            g.attr("transform", event.transform);
        });

    svg.call(zoom);

    const root = d3.stratify()
        .id(d => d.id)
        .parentId(d => d.padreId)(data);

    root.x0 = width / 2;
    root.y0 = 0;

    const treeLayout = d3.tree()
        .size([width - 100, height - 150]);

    // 🔥 colapsar todo menos raíz
    root.children.forEach(collapse);

    update(root);

    function collapse(d) {
        if (d.children) {
            d._children = d.children;
            d._children.forEach(collapse);
            d.children = null;
        }
    }

    function update(source) {

        treeLayout(root);

        const nodes = root.descendants();
        const links = root.links();

        // 🔗 LINKS
        g.selectAll("path.link")
        .data(links, d => d.target.id)
        .join("path")
        .attr("class", "link")
        .attr("fill", "none")
        .attr("stroke", "#38BDF8")
        .attr("stroke-width", 1.5)
        .attr("d", d => {

            const offset = 18; // 🔥 mitad del alto del nodo

            const sourceX = d.source.x;
            const sourceY = d.source.y + offset;

            const targetX = d.target.x;
            const targetY = d.target.y - offset;

            const midY = sourceY + (targetY - sourceY) * 0.4;

            return `
                M${sourceX},${sourceY}
                C${sourceX},${midY}
                ${targetX},${midY}
                ${targetX},${targetY}
            `;
        });

        // 🧠 NODOS
        const node = g.selectAll("g.node")
            .data(nodes, d => d.id);

        const nodeEnter = node.enter()
            .append("g")
            .attr("class", "node")
            .attr("transform", d => `translate(${source.x0},${source.y0})`)
            .on("click", (event, d) => {
                if (d.children) {
                    d._children = d.children;
                    d.children = null;
                } else {
                    d.children = d._children;
                    d._children = null;
                }
                update(d);
            });

        // 🔳 caja
        nodeEnter.append("rect")
            .attr("x", -45)
            .attr("y", -18)
            .attr("width", 90)
            .attr("height", 36)
            .attr("rx", 10)
            .attr("fill", "#0F172A")
            .attr("stroke", d => colorPorRango(d.data.rango))
            .attr("stroke-width", 2);

        // 👤 nombre
        nodeEnter.append("text")
            .attr("text-anchor", "middle")
            .attr("dy", "-2")
            .attr("fill", "#EAF0FF")
            .style("font-size", "11px")
            .style("font-weight", "600")
            .text(d => d.data.nombre);

        // 🏷️ estado
        nodeEnter.append("text")
            .attr("text-anchor", "middle")
            .attr("dy", "12")
            .attr("fill", "#94a3b8")
            .style("font-size", "10px")
            .text(d => d.data.estado ?? d.data.rango);

        // 🔥 TOOLTIP
        const tooltip = d3.select("body")
            .append("div")
            .style("position", "absolute")
            .style("background", "#020617")
            .style("padding", "8px 12px")
            .style("border-radius", "8px")
            .style("font-size", "12px")
            .style("color", "#EAF0FF")
            .style("border", "1px solid #38BDF8")
            .style("display", "none");

        nodeEnter.on("mouseover", (event, d) => {
            tooltip
                .style("display", "block")
                .html(`
                    <strong>${d.data.nombre}</strong><br/>
                    Estado: ${d.data.estado}<br/>
                    Rango: ${d.data.rango}<br/>
                    Puntos: ${d.data.comision ?? 0}
                `);
        })
        .on("mousemove", event => {
            tooltip
                .style("top", (event.pageY + 10) + "px")
                .style("left", (event.pageX + 10) + "px");
        })
        .on("mouseout", () => {
            tooltip.style("display", "none");
        });

        // animación
        nodeEnter.merge(node)
            .transition()
            .duration(300)
            .attr("transform", d => `translate(${d.x},${d.y})`);

        node.exit().remove();

        // guardar posiciones
        nodes.forEach(d => {
            d.x0 = d.x;
            d.y0 = d.y;
        });
    }

});

// 🎨 colores
function colorPorRango(rango) {
    switch (rango) {
        case "Diamante": return "#60A5FA";
        case "Platino": return "#22D3EE";
        case "Oro": return "#FFD700";
        case "Plata": return "#C0C0C0";
        case "Bronce": return "#F97316";
        case "Cobre": return "#8B5A2B";
        default: return "#64748B";
    }
}
</script>