@* Exito.cshtml — Views/Pagos/Exito.cshtml *@
@{ ViewData["Title"] = "Pago exitoso"; Layout = "_Layout"; }

<div class="centered-page">
    <div style="text-align:center; max-width:440px;">
        <div style="font-size:56px; margin-bottom:16px;">✅</div>
        <div class="pago-resultado success" style="margin:0;">
            <h2>¡Pago exitoso!</h2>
            <p>Tu pago fue procesado correctamente. La cuenta del referidor se activó y las comisiones fueron distribuidas automáticamente.</p>
            <p class="redirect">Redirigiendo al panel en <span id="contador">5</span> segundos...</p>
            <div style="margin-top:20px;">
                <a href="/Usuario/Panel" class="btn btn-primary">Ir al panel ahora</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let s = 5;
    const el = document.getElementById("contador");
    const t = setInterval(() => { s--; el.textContent = s; if (s <= 0) { clearInterval(t); window.location.href = "/Usuario/Panel"; } }, 1000);
</script>
}
