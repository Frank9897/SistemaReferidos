@{
    Layout = "_Layout";
}

<div class="pago-resultado error">
    <h2>❌ Error en el pago</h2>

    <p>
        Hubo un problema al procesar tu pago. 
        Puedes intentarlo nuevamente o contactar soporte.
    </p>

    <p class="redirect">
        Volviendo al panel en <span id="contador">3</span> segundos...
    </p>
</div>

<script>
    let segundos = 3;
    const contador = document.getElementById("contador");

    const intervalo = setInterval(() => {
        segundos--;
        contador.innerText = segundos;

        if (segundos <= 0) {
            clearInterval(intervalo);
            window.location.href = "/Usuario/Panel";
        }
    }, 1000);
</script>