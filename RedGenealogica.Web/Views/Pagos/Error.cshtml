@* Pendiente.cshtml — Views/Pagos/Pendiente.cshtml *@
@{ ViewData["Title"] = "Pago pendiente"; Layout = "_Layout"; }

<div class="centered-page">
    <div style="text-align:center; max-width:440px;">
        <div style="font-size:56px; margin-bottom:16px;">⏳</div>
        <div class="pago-resultado pending" style="margin:0;">
            <h2>Pago pendiente</h2>
            <p>Tu pago está siendo procesado. Esto puede tardar unos minutos dependiendo del medio de pago. Recibirás una notificación cuando se confirme.</p>
            <p class="redirect">Volviendo al panel en <span id="contador">5</span> segundos...</p>
            <div style="margin-top:20px;">
                <a href="/Usuario/Panel" class="btn btn-secondary">Ir al panel</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let s = 5;
    const el = document.getElementById("contador");
    const t = setInterval(() => { s--; el.textContent = s; if (s <= 0) { clearInterval(t); window.location.href = "/Usuario/Panel"; } }, 1000);
</script>
}
