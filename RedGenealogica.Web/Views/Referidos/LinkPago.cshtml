@* LinkPago.cshtml — Views/Referidos/LinkPago.cshtml — CORREGIDO *@
@using RedGenealogica.Web.Enumeraciones
@{ ViewData["Title"] = "Link de pago"; var referido = ViewBag.Referido as RedGenealogica.Web.Models.Referido; var urlPago = ViewBag.UrlPago as string; var cuentaActiva = ViewBag.CuentaActiva as bool? ?? false; }

<div class="centered-page">
    <div class="center-box">
        <div class="section-title">💳 Link de pago</div>
        <div class="section-subtitle">Compartí este link con tu referido para que complete el pago</div>

        <div class="card">
            <div style="margin-bottom:18px;">
                <div style="font-size:12px; color:var(--text-muted); margin-bottom:4px;">REFERIDO</div>
                <div style="font-weight:600; font-size:16px;">@referido?.NombreCompleto</div>
                @if (!string.IsNullOrEmpty(referido?.CorreoElectronico))
                {
                    <div style="font-size:13px; color:var(--text-muted);">@referido.CorreoElectronico</div>
                }
            </div>

            <div class="divider"></div>

            <div style="margin:18px 0;">
                <div style="font-size:12px; color:var(--text-muted); margin-bottom:8px;">LINK DE PAGO DIRECTO</div>
                <div style="background:var(--bg3); border:1px solid var(--border); border-radius:var(--radius-sm); padding:12px 14px; font-size:13px; color:var(--sky); word-break:break-all; font-family:monospace;">
                    @urlPago
                </div>
                <button onclick="navigator.clipboard.writeText('@urlPago'); this.textContent='¡Copiado!';" class="btn btn-secondary btn-sm" style="margin-top:8px;">
                    Copiar link
                </button>
            </div>

            <div class="divider"></div>

            @if (cuentaActiva)
            {
                <div style="background:rgba(34,197,94,0.07); border:1px solid rgba(34,197,94,0.2); border-radius:var(--radius-sm); padding:12px 14px; font-size:13px; color:var(--text-muted); display:flex; gap:10px; align-items:flex-start;">
                    <span style="color:var(--green); font-size:16px; flex-shrink:0;">✓</span>
                    <span>Tu cuenta ya está <strong style="color:var(--green);">activa</strong>. Cuando tu referido pague, recibirás las comisiones automáticamente.</span>
                </div>
            }
            else
            {
                <div style="background:rgba(56,189,248,0.06); border:1px solid rgba(56,189,248,0.15); border-radius:var(--radius-sm); padding:12px 14px; font-size:13px; color:var(--text-muted); display:flex; gap:10px; align-items:flex-start;">
                    <span style="font-size:16px; flex-shrink:0;">💡</span>
                    <span>Una vez que tu referido complete el pago, tu cuenta se <strong style="color:var(--sky);">activará automáticamente</strong> y comenzarás a ganar comisiones.</span>
                </div>
            }
        </div>

        @await Html.PartialAsync("_BotonVolver")
    </div>
</div>
