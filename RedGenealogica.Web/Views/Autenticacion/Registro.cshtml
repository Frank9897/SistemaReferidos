@* Registro.cshtml — Views/Autenticacion/Registro.cshtml *@
@model RedGenealogica.Web.ViewModels.RegistroUsuarioViewModel
@{ ViewData["Title"] = "Registro"; }

<div class="centered-page">
    <div class="center-box">

        <div style="text-align:center; margin-bottom:24px;">
            <div style="font-family:'Space Grotesk',sans-serif; font-size:26px; font-weight:700; background:linear-gradient(90deg,var(--sky),var(--indigo)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;">◆ RedGenealogica</div>
            <div style="color:var(--text-muted); font-size:14px; margin-top:6px;">Creá tu cuenta</div>
        </div>

        <div class="card">
            <div asp-validation-summary="All" class="validation-summary-errors"></div>

            <form method="post">

                <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                    <div class="form-group">
                        <label asp-for="Nombres">Nombres</label>
                        <input asp-for="Nombres" placeholder="Juan" />
                        <span asp-validation-for="Nombres" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Apellidos">Apellidos</label>
                        <input asp-for="Apellidos" placeholder="Pérez" />
                        <span asp-validation-for="Apellidos" class="field-validation-error"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Email">Correo electrónico</label>
                    <input asp-for="Email" type="email" placeholder="tu@email.com" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password">Contraseña</label>
                    <input asp-for="Password" type="password" placeholder="Mínimo 8 caracteres" />
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmarPassword">Confirmar contraseña</label>
                    <input asp-for="ConfirmarPassword" type="password" placeholder="••••••••" />
                    <span asp-validation-for="ConfirmarPassword" class="field-validation-error"></span>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model?.CodigoReferidoPadre))
                {
                    <div class="form-group">
                        <label asp-for="CodigoReferidoPadre">Código de referido</label>
                        <input asp-for="CodigoReferidoPadre" readonly style="opacity:0.6;" />
                    </div>
                }
                else
                {
                    <div class="form-group">
                        <label asp-for="CodigoReferidoPadre">Código de referido (opcional)</label>
                        <input asp-for="CodigoReferidoPadre" placeholder="Ingresá el código si tenés uno" />
                    </div>
                }

                <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center; padding:11px; margin-top:4px;">
                    Crear cuenta
                </button>
            </form>

            <div style="text-align:center; margin-top:18px; font-size:13px; color:var(--text-muted);">
                ¿Ya tenés cuenta?
                <a href="/Autenticacion/Login" style="color:var(--sky); margin-left:4px;">Iniciá sesión</a>
            </div>
        </div>

    </div>
</div>
