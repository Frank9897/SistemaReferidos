@* Retiros.cshtml — Views/Administrador/Retiros.cshtml *@
@model List<RedGenealogica.Web.Models.SolicitudRetiro>
@using RedGenealogica.Web.Enumeraciones
@{ ViewData["Title"] = "Admin — Retiros"; }

<div class="admin-tabs">
    <a href="/Administrador/Usuarios" class="admin-tab">Usuarios</a>
    <a href="/Administrador/Productos" class="admin-tab">Productos</a>
    <a href="/Administrador/Retiros" class="admin-tab active">Retiros</a>
</div>

<div class="card">
    <div class="card-header">
        <span class="card-title">💸 Solicitudes de retiro pendientes (@Model.Count)</span>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">✅</div>
            <p>No hay solicitudes pendientes</p>
        </div>
    }
    else
    {
        @foreach (var s in Model)
        {
            <div style="border:1px solid var(--border); border-radius:var(--radius); padding:18px; margin-bottom:12px;">
                <div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:12px;">
                    <div>
                        <div style="font-weight:600; font-size:15px;">@s.Usuario?.Nombres @s.Usuario?.Apellidos</div>
                        <div style="font-size:12.5px; color:var(--text-muted);">@s.Usuario?.Email</div>
                        <div style="margin-top:8px;">
                            <span style="font-family:'Space Grotesk',sans-serif; font-size:22px; font-weight:700; color:var(--green);">$@s.Monto.ToString("N2")</span>
                        </div>
                        <div style="font-size:12px; color:var(--text-muted); margin-top:4px;">
                            CBU/Alias: <strong style="color:var(--text);">@s.CbuAlias</strong>
                        </div>
                        <div style="font-size:12px; color:var(--text-muted);">
                            Solicitado: @s.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")
                        </div>
                    </div>

                    <div style="display:flex; flex-direction:column; gap:10px; min-width:260px;">
                        <!-- Aprobar -->
                        <form method="post" action="/Administrador/AprobarRetiro/@s.Id">
                            @Html.AntiForgeryToken()
                            <div style="margin-bottom:6px;">
                                <label style="font-size:11px;">Referencia de transferencia *</label>
                                <input name="referenciaTransferencia" required placeholder="ID de transferencia MP" style="margin-bottom:6px;" />
                                <input name="nota" placeholder="Nota (opcional)" />
                            </div>
                            <button type="submit" class="btn btn-success" style="width:100%; justify-content:center;">✓ Aprobar y completar</button>
                        </form>

                        <div style="text-align:center; font-size:11px; color:var(--text-dim);">— o —</div>

                        <!-- Rechazar -->
                        <form method="post" action="/Administrador/RechazarRetiro/@s.Id">
                            @Html.AntiForgeryToken()
                            <div style="margin-bottom:6px;">
                                <label style="font-size:11px;">Motivo de rechazo *</label>
                                <input name="motivo" required placeholder="Ej: Saldo insuficiente verificado" />
                            </div>
                            <button type="submit" class="btn btn-danger" style="width:100%; justify-content:center;">✕ Rechazar</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
</div>
