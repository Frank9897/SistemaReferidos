@model RedGenealogica.Web.ViewModels.PanelUsuarioViewModel
@using RedGenealogica.Web.Enumeraciones
<div class="main-container">

    <!-- HEADER -->
    <div class="card">
        <h1 class="titulo-principal">Hola, @Model.Usuario.Nombres 👋</h1>
        <p class="subtitulo">Sigue construyendo tu red y sube de nivel</p>

        <br />

        <span class="badge @(Model.Usuario.TipoRangoActual.ToString().ToLower())">
            @Model.Usuario.TipoRangoActual
        </span>
    </div>

    <!-- METRICAS -->
    <div class="grid">

        <div class="card">
            <div class="metric metric-blue">@Model.Usuario.PuntosAcumulados</div>
            <div class="metric-label">Puntos totales</div>
        </div>

        <div class="card">
            <div class="metric metric-green">@Model.TotalReferidosDirectos</div>
            <div class="metric-label">Referidos directos</div>
        </div>

        <div class="card">
            <div class="metric metric-cyan">@Model.TotalReferidosIndirectos</div>
            <div class="metric-label">Referidos indirectos</div>
        </div>

        <div class="card">
            <div class="metric metric-purple">@Model.TotalReferidosDirectos + @Model.TotalReferidosIndirectos</div>
            <div class="metric-label">Total red</div>
        </div>

    </div>

    <!-- PROGRESO -->
    <div class="card">
        <h3>Progreso al siguiente rango</h3>

        @{
            int progreso = Model.ProgresoRangoPorcentaje;
        }

        <div class="progress-bar">
            <div class="progress-fill" style="width:@progreso%"></div>
        </div>

        <p class="subtitulo">@Model.PuntosFaltantesParaSiguienteRango puntos restantes</p>
            @if (!string.IsNullOrWhiteSpace(Model.SiguienteRango))
            {
                <p class="subtitulo">Siguiente rango: @Model.SiguienteRango</p>
            }
            </div>

    
    <!-- ACCIONES -->
    <div class="card">
        <h3>Acciones rápidas</h3>

        <br />

        <div class="acciones-inline">
            <a href="/Referidos/Crear" class="btn btn-primary">Registrar Referido</a>
            <a href="/Genealogia" class="btn btn-secondary">Ver Árbol</a>
            <a href="/Ranking" class="btn btn-secondary">Ver Ranking</a>
        </div>
    </div>

    <!-- REFERIDOS -->
    <div class="card">
        <h3>Mis Referidos</h3>

        <table class="table">
            <tr>
                <th>Nombre</th>
                <th>Estado</th>
                <th>Acción</th>
            </tr>

            @foreach (var r in Model.Referidos)
            {
                <tr>
                    <td>@r.NombreCompleto</td>

                    <td>
                        <span class="badge @(r.Estado == EstadoUsuario.Activo ? "badge-success" : "badge-warning")">
                            @r.Estado
                        </span>
                    </td>

                    <td>
                        @if (r.Estado != EstadoUsuario.Activo)
                        {
                            <a href="/Pagos/Pagar?referidoId=@r.Id" class="btn btn-primary btn-sm">
                                💳 Pagar
                            </a>
                        }
                        else
                        {
                            <span class="text-success">✔ Activo</span>
                        }
                    </td>
                </tr>
            }
        </table>
    </div>
    <!-- ULTIMO MOVIMIENTO -->
    <div class="card">
        <h3>Últimos movimientos</h3>

        <table class="table">
            <tr>
                <th>Fecha</th>
                <th>Motivo</th>
                <th>Puntos</th>
                <th>Monto</th>
            </tr>

            @foreach (var m in Model.UltimosMovimientos)
            {
                <tr>
                    <td>@m.FechaMovimiento.ToString("dd/MM/yyyy")</td>
                    <td>@m.Motivo</td>
                    <td>@m.CantidadPuntos</td>
                    <td>@m.Monto</td>
                </tr>
            }
        </table>
    </div>
</div>