@model RedGenealogica.Web.Models.Usuario

<h2>Panel de Usuario</h2>

<p><strong>Nombre:</strong> @Model.Nombres @Model.Apellidos</p>
<p><strong>Email:</strong> @Model.Email</p>
<p><strong>Puntos:</strong> @Model.PuntosAcumulados</p>
<p><strong>Estado:</strong> @Model.EstadoUsuario</p>
<p><strong>Rango:</strong> @Model.TipoRangoActual</p>

<hr />
<a href="/Referidos/Crear">Registrar Referido</a>

@if (Model.EstadoUsuario.ToString() != "Activo")
{
    <h3>Activar cuenta</h3>

    <form asp-action="ActivarCuenta" method="post">
        <button type="submit">Activar (Simulación de pago)</button>
    </form>
}
else
{
    <p style="color: green;">✔ Cuenta activa</p>
}

<hr />

    <h3>Mis Referidos</h3>

    <table>
        <tr>
            <th>Nombre</th>
            <th>Estado</th>
            <th>Acción</th>
        </tr>

        @foreach (var r in (List<RedGenealogica.Web.Models.Referido>)ViewBag.Referidos)
        {
            <tr>
                <td>@r.NombreCompleto</td>
                <td>@r.Estado</td>
                <td>
                    @if (r.Estado.ToString() != "Activo")
                    {
                        <form asp-controller="Referidos" asp-action="Activar" method="post">
                            <input type="hidden" name="id" value="@r.Id" />
                            <button type="submit">Activar (Pago)</button>
                        </form>
                    }
                    else
                    {
                        <span>✔ Activo</span>
                    }
                </td>
            </tr>
        }
    </table>

<form asp-controller="Autenticacion" asp-action="Logout" method="post">
    <button type="submit">Cerrar sesión</button>
</form>