@model RedGenealogica.Web.ViewModels.PanelUsuarioViewModel

<div class="container-dashboard">

    <!-- HEADER -->
    <div class="card">
        <h1 class="titulo-principal">Hola, @Model.Usuario.Nombres 👋</h1>
        <p class="subtitulo">Sigue construyendo tu red y sube de nivel</p>

        <br />

        <span class="badge @Model.Usuario.TipoRangoActual.ToString().ToLower()">
            @Model.Usuario.TipoRangoActual
        </span>
    </div>

    <!-- METRICAS -->
    <div class="grid">

        <div class="card">
            <div class="metric">@Model.Usuario.PuntosAcumulados</div>
            <div class="metric-label">Puntos totales</div>
        </div>

        <div class="card">
            <div class="metric">@((List<RedGenealogica.Web.Models.Referido>)ViewBag.Referidos).Count</div>
            <div class="metric-label">Referidos directos</div>
        </div>

        <div class="card">
            <div class="metric">0</div>
            <div class="metric-label">Referidos indirectos</div>
        </div>

        <div class="card">
            <div class="metric">@Model.Usuario.PuntosAcumulados / 100</div>
            <div class="metric-label">Total red</div>
        </div>

    </div>

    <!-- PROGRESO -->
    <div class="card">
        <h3>Progreso al siguiente rango</h3>

        @{
            int puntos = Model.Usuario.PuntosAcumulados;
            int siguiente = 1000;
            int progreso = (puntos * 100) / siguiente;
        }

        <div class="progress-bar">
            <div class="progress-fill" style="width:@progreso%"></div>
        </div>

        <p class="subtitulo">@((siguiente - puntos)) puntos restantes</p>
    </div>

    <!-- ACCIONES -->
    <div class="card">
        <h3>Acciones rápidas</h3>

        <br />

        <a href="/Referidos/Crear" class="btn btn-primary">Registrar Referido</a>
        <a href="/Genealogia" class="btn btn-secondary">Ver Árbol</a>
        <a href="/Ranking" class="btn btn-secondary">Ver Ranking</a>
    </div>

    <!-- REFERIDOS -->
    <div class="card">
        <h3>Mis Referidos</h3>

        <table class="table">
            <tr>
                <th>Nombre</th>
                <th>Estado</th>
            </tr>

            @foreach (var r in (List<RedGenealogica.Web.Models.Referido>)ViewBag.Referidos)
            {
                <tr>
                    <td>@r.NombreCompleto</td>
                    <td>@r.Estado</td>
                </tr>
            }
        </table>
    </div>

</div>