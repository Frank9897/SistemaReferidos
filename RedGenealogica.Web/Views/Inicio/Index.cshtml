@{
    ViewData["Title"] = "Inicio";
}

<div class="container-dashboard">
    <div class="card hero-card">
        <h1 class="titulo-principal">Sistema de Referidos</h1>
        <p class="subtitulo">Bienvenido al sistema</p>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <p class="subtitulo">Sesión iniciada como @User.Identity.Name</p>

            <div class="acciones-inline">
                <a href="/Usuario/Panel" class="btn btn-primary">Ir al panel</a>
                <a href="/Ranking" class="btn btn-secondary">Ver ranking</a>
            </div>
        }
        else
        {
            <div class="acciones-inline">
                <a href="/Autenticacion/Registro" class="btn btn-primary">Registrarse</a>
                <a href="/Autenticacion/Login" class="btn btn-secondary">Iniciar sesión</a>
            </div>
        }
    </div>
</div>